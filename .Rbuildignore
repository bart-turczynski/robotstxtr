# R build/dev artifacts
^.*\.Rproj$
^\.Rproj\.user$
^\.Rhistory$
^\.RData$
^\.Ruserdata$
^.*\.Rcheck$
^.*\.tar\.gz$
^\.lintr$
^\.covrignore$
^cran-comments\.md$
^CRAN-SUBMISSION$
^LICENSE\.md$
^THIRD_PARTY_NOTICES\.md$
^doc$
^Meta$
# Shared scaffold layer: everything below is dev tooling, not package content,
# and would otherwise trip "non-standard files/directories" in R CMD check.
^\.github$
^\.editorconfig$
^\.env$
^\.env\.example$
^\.gitattributes$
^\.gitignore$
^\.pre-commit-config\.yaml$
^\.fp$
^\.claude$
^FP_CLAUDE\.md$
^FP_AGENTS\.md$
^_scratch$
^dev$
^docs$
^design$
^CLAUDE\.md$
^AGENTS\.md$
^CONTRIBUTING\.md$
^SECURITY\.md$
^CHANGELOG\.md$
^\.DS_Store$
^_pkgdown\.yml$
^pkgdown$
^README\.Rmd$
^codemeta\.json$
^CITATION\.cff$
^\.zenodo\.json$
^SECURITY-INSIGHTS\.yml$
^CODE_OF_CONDUCT\.md$
