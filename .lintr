linters: linters_with_defaults(
    # object_usage_linter misreads cross-file package internals (e.g. the
    # validate_*/perform_fetch helpers) and testthat's expect_* DSL as
    # undefined globals, producing false positives. Disabled to keep the lint
    # gate clean.
    object_usage_linter = NULL
  )
encoding: "UTF-8"
